<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 배경 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFEBEE" />
            <corners android:radius="8dp" />
            <stroke
                android:width="1dp"
                android:color="#FFCDD2" />
        </shape>
    </item>

    <!-- X 표시 -->
    <item
        android:width="24dp"
        android:height="24dp"
        android:gravity="center">
        <rotate
            android:fromDegrees="45"
            android:toDegrees="45">
            <shape android:shape="rectangle">
                <solid android:color="#EF5350" />
                <size
                    android:width="2dp"
                    android:height="24dp" />
            </shape>
        </rotate>
    </item>
    <item
        android:width="24dp"
        android:height="24dp"
        android:gravity="center">
        <rotate
            android:fromDegrees="-45"
            android:toDegrees="-45">
            <shape android:shape="rectangle">
                <solid android:color="#EF5350" />
                <size
                    android:width="2dp"
                    android:height="24dp" />
            </shape>
        </rotate>
    </item>
</layer-list>